{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profiles including their full name, email, role, and block status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "blocked": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "fullName", "email", "role", "blocked", "createdAt"]
    },
    "Examination": {
      "title": "Examination",
      "description": "Stores examination papers created by admins.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "term": { "type": "string" },
        "duration": { "type": "number" },
        "numQuestions": { "type": "number" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "subject", "grade", "term", "duration", "numQuestions", "published", "createdAt", "questions"]
    },
    "Attempt": {
      "title": "Attempt",
      "description": "Stores student exam attempts and their detailed scores/answers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "examId": { "type": "string" },
        "examTitle": { "type": "string" },
        "examSubject": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "percentage": { "type": "number" },
        "timeTaken": { "type": "number" },
        "date": { "type": "string" },
        "answers": { "type": "object" },
        "questionsSnapshot": { "type": "array" }
      },
      "required": ["id", "studentId", "studentName", "examId", "examTitle", "examSubject", "score", "maxScore", "percentage", "timeTaken", "date", "answers", "questionsSnapshot"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles indexed by their Auth UID."
    },
    "/examinations/{examId}": {
      "schema": "Examination",
      "description": "Examination details indexed by a unique Exam ID."
    },
    "/attempts/{attemptId}": {
      "schema": "Attempt",
      "description": "Records of exam attempts by students indexed by Attempt ID."
    }
  }
}
